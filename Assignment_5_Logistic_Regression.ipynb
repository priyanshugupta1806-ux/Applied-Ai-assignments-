      "source": [
        "from sklearn.linear_model import LogisticRegression\n",
        "\n",
        "# Sample data\n",
        "X = [[1,2],[2,3],[3,4],[10,10],[11,11]]\n",
        "y = [0,0,0,1,1]\n",
        "\n",
        "# Create model\n",
        "model = LogisticRegression()\n",
        "\n",
        "# Train model\n",
        "model.fit(X, y)\n",
        "\n",
        "# Predict\n",
        "predictions = model.predict(X)\n",
        "\n",
        "print(\"Predictions:\", predictions)"
      ]
    }
  ]
}